{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "【A】运行 join 模块",
            "type": "shell",
            "command": "gcc -DTEST_JOIN_MODULE function/join/join.c -o test_join.exe && test_join.exe"
        },
        {
            "label": "【B】运行 publish 模块",
            "type": "shell",
            "command": "gcc -DTEST_PUBLISH_MODULE function/publish/publish.c -o test_publish.exe && test_publish.exe"
        },
        {
            "label": "【C】运行 comment 模块",
            "type": "shell",
            "command": "gcc -DTEST_COMMENT_MODULE function/comment/comment.c -o test_comment.exe && test_comment.exe"
        },
        {
            "label": "编译整个项目",
            "type": "shell",
            "command": "gcc core/*.c data/*.c function/*/*.c main.c -o main.exe"
        },
        {
            "label": "运行整个项目",
            "type": "shell",
            "command": "main.exe"
        }
    ]
}