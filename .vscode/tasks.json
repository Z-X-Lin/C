{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "【A】运行 join 模块",
            "type": "shell",
            "command": "gcc -I. -Icore -Idata -Ifunction -DTEST_JOIN_MODULE function/join/join.c -o test_join.exe && test_join.exe"
        },
        {
            "label": "【B】运行 publish 模块",
            "type": "shell",
            "command": "gcc -I. -Icore -Idata -Ifunction -DTEST_PUBLISH_MODULE function/publish/publish.c -o test_publish.exe && test_publish.exe"
        },
        {
            "label": "【C】运行 comment 模块",
            "type": "shell",
            "command": "gcc -I. -Icore -Idata -Ifunction -DTEST_COMMENT_MODULE function/comment/comment.c -o test_comment.exe && test_comment.exe"
        },
        {
            "label": "编译整个项目",
            "type": "shell",
            "command": "gcc -I. -Icore -Idata -Ifunction core/*.c data/*.c function/*/*.c main.c -o main.exe"
        },
        {
            "label": "运行整个项目",
            "type": "shell",
            "command": "main.exe"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "D:\\mingw64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-I${workspaceFolder}",
                "-I${workspaceFolder}/core",
                "-I${workspaceFolder}/data",
                "-I${workspaceFolder}/function"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ]
}