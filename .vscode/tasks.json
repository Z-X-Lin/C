{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "gcc.exe",
            "args": [
                "-g",
                "main.c",
                "common.c",
                "user.c",
                "post.c",
                "join.c",
                "-o",
                "${workspaceFolder}\\solotogether.exe",
                "-Wall",
                "-Wextra"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "编译校园搭子系统"
        },
        {
            "label": "run",
            "type": "shell",
            "command": "${workspaceFolder}\\solotogether.exe",
            "dependsOn": "build",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "detail": "运行校园搭子系统"
        },
        {
            "label": "build & run",
            "dependsOn": [
                "build",
                "run"
            ],
            "problemMatcher": [],
            "detail": "一键编译运行"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "windows": {
        "options": {
            "shell": {
                "executable": "cmd.exe",
                "args": [
                    "/c"
                ]
            }
        }
    }
}